# =============================================================================
# AgentMarket Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker-compose.

# -----------------------------------------------------------------------------
# API Keys (Required)
# -----------------------------------------------------------------------------

# OpenRouter API key (primary - used by openclaw.json for model routing)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# OpenClaw Gateway
# -----------------------------------------------------------------------------

# Authentication token for the OpenClaw gateway API
OPENCLAW_GATEWAY_TOKEN=agentmarket-dev-token

# -----------------------------------------------------------------------------
# Agent Private Keys (Required for Commerce & Merchant agents)
# -----------------------------------------------------------------------------

# Private key for the Commerce Agent's on-chain wallet
# Used to sign transactions for hiring agents, making payments, etc.
COMMERCE_AGENT_KEY=0x...

# Private key for the Merchant Agent's on-chain wallet
# Used to sign transactions for merchant registration, checkouts, withdrawals
MERCHANT_AGENT_KEY=0x...

# -----------------------------------------------------------------------------
# Paymaster (Required for gasless transactions)
# -----------------------------------------------------------------------------

# Private key for the ADI Paymaster signer
# Signs paymaster approvals so users get zero-gas transactions
PAYMASTER_SIGNER_KEY=0x...

# -----------------------------------------------------------------------------
# Hedera Testnet (Required for Hedera DeFi operations)
# -----------------------------------------------------------------------------

# Private key for Hedera DeFi agent operations (swaps, lending, etc.)
# Must be funded with testnet HBAR from https://portal.hedera.com
HEDERA_PRIVATE_KEY=0x...

# Hedera account ID corresponding to the private key above
# Look up at: https://testnet.mirrornode.hedera.com/api/v1/accounts/<evm_address>
HEDERA_ACCOUNT_ID=0.0.XXXXXXX

# -----------------------------------------------------------------------------
# 0G Compute Network - Galileo Testnet (Required for AI inference)
# -----------------------------------------------------------------------------

# Private key for 0G Galileo Testnet wallet (chain ID 16602)
# Used for decentralized AI inference via 0G Compute Network
# Must be funded with testnet 0G tokens
# RPC: https://evmrpc-testnet.0g.ai
# Explorer: https://chainscan-galileo.0g.ai
OG_PRIVATE_KEY=0x...
