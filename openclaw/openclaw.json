{
  "env": {
    "OPENROUTER_API_KEY": "${OPENROUTER_API_KEY}"
  },
  "gateway": {
    "mode": "local",
    "port": 18789,
    "auth": {
      "token": "${OPENCLAW_GATEWAY_TOKEN}"
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openrouter/google/gemini-2.0-flash-001",
        "fallbacks": ["openrouter/google/gemini-2.5-flash-preview", "openrouter/anthropic/claude-sonnet-4-5"]
      }
    },
    "list": [
      {
        "id": "commerce",
        "default": true,
        "name": "Commerce Agent",
        "workspace": "/data/workspace-commerce",
        "agentDir": "/data/agents/commerce/agent"
      },
      {
        "id": "merchant",
        "name": "Merchant Agent",
        "workspace": "/data/workspace-merchant",
        "agentDir": "/data/agents/merchant/agent"
      },
      {
        "id": "analytics",
        "name": "Analytics Agent",
        "workspace": "/data/workspace-analytics",
        "agentDir": "/data/agents/analytics/agent"
      },
      {
        "id": "defi",
        "name": "DeFi Agent",
        "workspace": "/data/workspace-defi",
        "agentDir": "/data/agents/defi/agent"
      }
    ]
  },
  "skills": {
    "load": {
      "extraDirs": ["/data/skills"]
    }
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["commerce", "merchant", "analytics", "defi"]
    },
    "mcp": {
      "servers": [
        {
          "id": "agentmarket",
          "name": "AgentMarket MCP",
          "command": "node",
          "args": ["/app/mcp-server/dist/index.js"],
          "env": {
            "AGENT_PRIVATE_KEY": "${COMMERCE_AGENT_KEY}",
            "HEDERA_PRIVATE_KEY": "${HEDERA_PRIVATE_KEY}",
            "HEDERA_ACCOUNT_ID": "${HEDERA_ACCOUNT_ID}",
            "OG_PRIVATE_KEY": "${OG_PRIVATE_KEY}",
            "FRONTEND_URL": "${FRONTEND_URL}"
          }
        }
      ]
    }
  },
  "channels": {}
}
